# ==== Thông tin đăng nhập / cấu hình dùng chung cho toàn bộ stack ====
# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me
# Bucket dùng làm warehouse cho Iceberg
WAREHOUSE_BUCKET=warehouse

# AWS-style creds (Iceberg/Spark/Trino đọc từ đây để nói chuyện với MinIO)
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=change-me
AWS_REGION=us-east-1

# Iceberg version dùng cho Spark runtime jars
ICEBERG_VERSION=1.9.2

# Postgres làm metastore cho Iceberg REST catalog (lưu namespace/bảng)
CATALOG_DB_NAME=iceberg
CATALOG_DB_USER=iceberg
CATALOG_DB_PASSWORD=change-me
